RewriteEngine On

# 1. FORÇAR HTTPS (descomente em produção)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# 2. REDIRECIONAR www → non-www (descomente em produção)
# RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
# RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# 3. REMOVER TRAILING SLASH (exceto raiz)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [R=301,L]

# 4. PÁGINA INICIAL: redirecionar /index.php e /home para /
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+index\.php [NC]
RewriteRule ^index\.php$ / [R=301,L]

# 5. BLOQUEAR ACESSO DIRETO A ARQUIVOS SENSÍVEIS
RewriteRule ^(env\.php|api\.php|router\.php)$ - [F,L]

# 6. HEADERS DE SEGURANÇA
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# 7. COMPRESSÃO GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml application/rss+xml image/svg+xml
</IfModule>

# 8. CACHE DE ARQUIVOS ESTÁTICOS (1 mês para assets versionados)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# 9. PÁGINA DE ERRO 404 PERSONALIZADA
ErrorDocument 404 /index.php

# 10. Ignora arquivos e pastas que realmente existem (sitemap.xml, robots.txt, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
# Manda tudo para o seu arquivo index.php
RewriteRule ^ index.php [L]
